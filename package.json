{
  "name": "playwrightdemoproject",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:allure": "sh -c 'playwright test; ec=$?; allure generate allure-results --clean -o allure-report; allure open allure-report; exit $ec'",
    "test:report": "npm test; npm run allure:report",
    "test:products": "playwright test e2e/greenkart-products.spec.ts",
    "test:checkout": "playwright test e2e/greenkart-checkout.spec.ts",
    "test:ui": "playwright test --ui --project=ios",
    "test:headed": "playwright test --headed",
    "report": "npm run allure:report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1"
  }
}
